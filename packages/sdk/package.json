    "proxy-agent": "^8.0.1",
    "simple-git": "^3.36.0",
    "string-width": "^8.2.0",
    "typescript": "^6.0.2",
    "undici": "^8.0.2",
    "yaml": "^2.9.0",
    "zod": "^4.3.6"
  },
