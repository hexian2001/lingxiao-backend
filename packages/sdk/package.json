{
  "name": "@lingxiao-office/sdk",
  "version": "1.0.6",
  "description": "凌霄剑域可复用后端引擎 SDK：编排内核、Agent 运行时、LLM 客户端、工具系统、记忆系统。不依赖 Web API，可直接嵌入任意产品线。",
  "license": "MIT",
  "keywords": [
    "agent",
    "llm",
    "ai",
    "sdk",
    "orchestration",
    "multi-agent",
    "tool-calling",
    "framework",
    "lingxiao"
  ],
  "author": "Lingxiao Office",
  "homepage": "https://github.com/hexian2001/lingxiao-office-sdk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hexian2001/lingxiao-office-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/hexian2001/lingxiao-office-sdk/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*",
      "import": "./dist/*"
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^3.0.101",
