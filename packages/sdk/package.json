    "@anthropic-ai/sdk": "^0.82.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.1",
    "@fastify/websocket": "^11.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "acorn": "^8.16.0",
    "ai": "^5.0.198",
    "ajv": "^8.17.1",
    "chokidar": "^5.0.0",
    "fastify": "^5.8.4",
    "glob": "^13.0.6",
    "js-tiktoken": "^1.0.21",
    "node-fetch": "^3.3.2",
